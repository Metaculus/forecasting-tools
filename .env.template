PYTHONPATH=.


# As of Feb 16th 2026 Asknews amd Openrouter are the most heavily used in agents.
OPENROUTER_API_KEY=
ASKNEWS_API_KEY=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
EXA_API_KEY=
PERPLEXITY_API_KEY=

# Fill this in if using the Metaculus API
METACULUS_TOKEN=
METACULUS_API_BASE_URL=https://www.metaculus.com/api

# As of Jan 23rd 2025, only used for free semantic similarity calculation in Deduplicator, but defaults to OpenAI if not filled in
HUGGINGFACE_API_KEY=

# As of Jun 10 2025, used for browser use agents
HYPERBROWSER_API_KEY=

# Disable if in Streamlit Cloud
FILE_WRITING_ALLOWED=TRUE


# --- Source archive (agents_and_tools/source_archive) ---
# Requires the optional extra: pip install forecasting-tools[source-archive]
# Captures HTML + screenshot + markdown for the URLs a bot cited and stores them
# in S3. AWS credentials are resolved by the standard AWS chain (env vars,
# shared config, SSO profile) — never commit them. Leave blank to store locally.
WEB_ARCHIVE_S3_BUCKET=
# Optional: key prefix within the bucket (defaults to "source-archive")
WEB_ARCHIVE_S3_PREFIX=
# Optional: named AWS profile to use (e.g. an SSO profile). Blank = default chain.
WEB_ARCHIVE_AWS_PROFILE=
# Optional: days before a cached capture is refetched (defaults to 14)
WEB_ARCHIVE_TTL_DAYS=
# Optional fallback scraper for sites that block headless Chromium
FIRECRAWL_API_KEY=
# Set WEB_ARCHIVE_S3_BUCKET above to a bucket you own/have access to; leave it
# blank to store captures locally instead.
